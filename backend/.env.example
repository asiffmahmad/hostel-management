# ─────────────────────────────────────────────────────────────────
# .env.example — SAFE TO COMMIT — contains NO real secrets
# Copy this file to .env and fill in your own values for local dev.
# Production values must be set in Render Environment Variables.
# ─────────────────────────────────────────────────────────────────

# Database
DB_URL=jdbc:mysql://<host>:<port>/<database>?sslMode=VERIFY_IDENTITY
DB_USERNAME=<db_username>
DB_PASSWORD=<db_password>
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=<64_hex_chars>

# AES-256 Encryption Key — must be exactly 32 ASCII chars
# Generate with: openssl rand -hex 16
APP_ENCRYPTION_SECRET=<32_ascii_chars>

# HMAC-SHA256 Hash Salt — generate with: openssl rand -hex 16
APP_HASH_SALT=<32_hex_chars>
